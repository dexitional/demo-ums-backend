// GENERAL LOGGING

model log {
  id        String   @id @default(uuid())
  action    String   @db.VarChar(255)
  user      String?  @db.VarChar(255)
  student   String?  @db.VarChar(255)
  meta      Json
  createdAt DateTime @default(now())
}

// AIS - ACADEMIC MANAGEMENT  MODELS

model country {
  id          String   @id @default(uuid())
  code        Int?     @db.Int
  shortName   String?  @db.VarChar(10)
  longName    String   @db.VarChar(255)
  nationality String?  @db.VarChar(300)
  status      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  studentCountry     student[]     @relation("studentCountry")
  studentNationality student[]     @relation("studentNationality")
  profileNationality stepProfile[] @relation("profileNationality")
  profileCountry     stepProfile[] @relation("profileCountry")
  staff              staff[]
  nss                nss[]
}

model region {
  id        String   @id @default(uuid())
  tag       String   @db.VarChar(50)
  title     String   @db.VarChar(255)
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student     student[]
  stepProfile stepProfile[]
  staff       staff[]
  nss         nss[]
}

model title {
  id        String   @id @default(uuid())
  tag       String   @db.VarChar(50)
  label     String   @db.VarChar(50)
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student      student[]
  stepProfile  stepProfile[]
  stepGuardian stepGuardian[]
  stepReferee  stepReferee[]
  staff        staff[]
  nss          nss[]
  relative     relative[]
}

model relation {
  id        String   @id @default(uuid())
  title     String   @db.VarChar(255)
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stepGuardian stepGuardian[]
  relative     relative[]
}

model marital {
  id        String   @id @default(uuid())
  title     String   @db.VarChar(255)
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff   staff[]
  student student[]
  nss     nss[]
  profile stepProfile[]
}

// 'SINGLE','MARRIED','SEPARATED','WIDOW','DIVORCED','NONE'

model religion {
  id        String   @id @default(uuid())
  title     String   @db.VarChar(255)
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student     student[]
  stepProfile stepProfile[]
  staff       staff[]
  nss         nss[]
}

model disability {
  id        String   @id @default(uuid())
  title     String   @db.VarChar(255)
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student     student[]
  stepProfile stepProfile[]
}

model unit {
  id             String   @id @default(uuid())
  code           String   @db.VarChar(50)
  title          String   @db.VarChar(255)
  type           unitType
  levelNum       Int
  level1Id       String?
  level2Id       String?
  level3Id       String?
  location       String?
  headStaffNo    String?
  subheadStaffNo String?
  status         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  level1 unit? @relation("level1", fields: [level1Id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  level2 unit? @relation("level2", fields: [level2Id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  level3 unit? @relation("level3", fields: [level3Id], references: [id], onDelete: SetNull, onUpdate: Cascade)

  levelI       unit[]         @relation("level1")
  levelII      unit[]         @relation("level2")
  levelIII     unit[]         @relation("level3")
  program      program[]
  structure    structure[]
  bankacc      bankacc[]
  positionInfo positionInfo[]
  fromUnit     transfer[]     @relation("fromUnit")
  toUnit       transfer[]     @relation("toUnit")
  staff        staff[]
  nss          nss[]
  sheet        sheet[]
}
